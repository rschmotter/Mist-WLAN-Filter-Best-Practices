# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed to the repository.
#
# Used by --auto (non-interactive) mode only.
# For interactive mode (--main), the script will prompt you instead.

# Mist cloud region (1-6):
#   1 = Global 01 / US   (api.mist.com)
#   2 = Global 02        (api.gc1.mist.com)
#   3 = Europe           (api.eu.mist.com)
#   4 = APAC AC2         (api.ac2.mist.com)
#   5 = APAC AC5         (api.ac5.mist.com)
#   6 = Canada           (api.ca.mist.com)
MIST_CLOUD=1

# Your Mist Organisation ID (UUID format, found under Org > Settings in the Mist portal)
MIST_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SuperUser API token (generated under Org > Settings > API Tokens in the Mist portal)
MIST_TOKEN=your_superuser_token_here
